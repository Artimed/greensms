# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Signing keys — never commit
*.keystore
*.jks
key.properties
android/key.properties

# Supabase secrets — replace with your real values before release
# lib/core/config/supabase_config.dart is tracked but contains placeholders only

# Flutter plugins generated
.flutter-plugins
